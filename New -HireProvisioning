# New Hire User Provisioning Script
# Author: Kolawole Odumade
# Purpose: Automates new hire AD user creation aligned with least-privilege principles

# Define new hire details
$FirstName = "John"
$LastName = "Doe"
$Username = "john.doe"
$Password = ConvertTo-SecureString "TempPass2026!" -AsPlainText -Force
$Department = "Sales"
$OU = "OU=Sales,OU=THM,DC=thmredteam,DC=com"
$Group = "Sales"

# Create the user account
New-ADUser `
    -GivenName $FirstName `
    -Surname $LastName `
    -SamAccountName $Username `
    -UserPrincipalName "$Username@yourdomain.com" `
    -Path $OU `
    -AccountPassword $Password `
    -Enabled $true `
    -ChangePasswordAtLogon $true `
    -Department $Department `
    -Verbose

# Add user to security group
Add-ADGroupMember -Identity $Group -Members $Username -Verbose

Write-Host "User $Username has been created and added to $Group group." -ForegroundColor Green
